# ============================================================
# Factory deploy — VPS .env
# ============================================================
# Copie : cp .env.example .env  puis remplis les valeurs.
# JAMAIS commit le .env (cf. .gitignore).

# ----- Domain config (DNS A records → IP du VPS) -----
N8N_HOST=n8n.themoodex.cards
SKILLS_HOST=skills.themoodex.cards

# ----- n8n core -----
# Générer : openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme-32-hex-chars
N8N_USER_MANAGEMENT_JWT_SECRET=changeme-32-hex-chars

# ----- Postgres -----
# Générer : openssl rand -hex 24
POSTGRES_PASSWORD=changeme-strong-pw

# ----- Inter-service auth -----
# Générer : openssl rand -hex 32
SKILLS_AUTH_SECRET=changeme-bearer-token

# ============================================================
# Skills Service env (mêmes variables que skills-service/.env)
# ============================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_STRATEGIST=claude-opus-4-6
ANTHROPIC_MODEL_SCORER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_ANALYST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6

# Notion (data_source_ids audités le 15/05/2026 dans TheMoodex HQ)
NOTION_API_KEY=ntn_xxx
NOTION_DS_CONTENT_CATALOG=30bfa615-c0f3-41ac-9546-fe1ffb0feecb
NOTION_DS_PRODUCTION_PIPELINE=059f17b2-efb1-4b19-8094-3eb418b40cc6
NOTION_DS_PERFORMANCE_TRACKER=7619b151-53b7-4e50-bf1b-596081d562c2
NOTION_DS_CHANNELS=7dc4115e-61e9-43dc-aedb-d45f6afed79b
NOTION_DS_CONTENT_THEMES=9bbffe7e-8e16-4f6f-8c91-e42e0bcc3da1
NOTION_DS_ASSET_TEMPLATES=a3067f9e-6e57-44f0-bab3-7fad49438965
NOTION_DS_PROMPTS_LIBRARY=c9205541-02de-4202-a539-0d3223a60730
NOTION_DS_ARCHETYPES=9a0ec201-1829-4ecb-97e2-69f426a46b7a

# fal.ai
FALAI_API_KEY=xxx
FALAI_IMAGE_MODEL=fal-ai/flux-pro/v1.1
FALAI_VIDEO_MODEL=fal-ai/kling-video/v2.5-turbo/image-to-video

# Creatomate
CREATOMATE_API_KEY=xxx
CREATOMATE_TEMPLATE_CARD=
CREATOMATE_TEMPLATE_VIDEO_FINAL=

# Epidemic Sound
EPIDEMIC_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=factory-assets
R2_PUBLIC_URL_BASE=https://assets.themoodex.cards

# Publishing (à compléter quand les comptes sont actifs)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
BUFFER_ACCESS_TOKEN=

# Telegram (bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Service
LOG_LEVEL=INFO
HTTP_TIMEOUT_DEFAULT=30
HTTP_TIMEOUT_LONG=300
