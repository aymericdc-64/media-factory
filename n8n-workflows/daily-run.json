        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"À produire\",\n  \"min_days_since_publish\": 30,\n  \"limit\": 20\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "skill-read-catalog",
      "name": "Skill · read_content_catalog",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "skills-bearer",
          "name": "Skills Service Bearer"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "anthropic-version", "value": "2023-06-01"},
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-6\",\n  \"max_tokens\": 4096,\n  \"system\": \"You are the Strategist agent of an automated social-media factory. Given a list of content concepts and recent performance data, pick 5 concepts to produce TODAY and return STRICT JSON: {\\\"briefs\\\":[{\\\"page_id\\\":\\\"...\\\",\\\"title\\\":\\\"...\\\",\\\"brief\\\":\\\"...\\\",\\\"script\\\":\\\"...\\\"}, ...]}.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Available concepts: {{ JSON.stringify($json.concepts) }}. Pick 5 for today.\"\n    }\n  ]\n}",
        "options": {"timeout": 60000}
      },
      "id": "agent-strategist",
      "name": "Agent · Strategist (Opus)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [620, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic-key",
          "name": "Anthropic API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse Claude's text response into 5 briefs\nconst content = $input.first().json.content || [];\nconst textBlock = content.find(c => c.type === 'text');\nif (!textBlock) throw new Error('Strategist returned no text');\nlet payload = textBlock.text.trim();\n// Strip ```json fences if any\nif (payload.startsWith('```')) {\n  payload = payload.replace(/^```(json)?/i, '').replace(/```$/, '').trim();\n}\nconst parsed = JSON.parse(payload);\nif (!parsed.briefs || parsed.briefs.length < 5) {\n  throw new Error(`Expected 5 briefs, got ${parsed.briefs ? parsed.briefs.length : 0}`);\n}\nreturn parsed.briefs.map(b => ({ json: b }));"
      },
      "id": "parse-briefs",
      "name": "Parse · 5 briefs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [840, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "split-5",
      "name": "Split (parallèle ×5)",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1060, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SKILLS_BASE_URL }}/strategist/write_brief_to_pipeline",
        "authentication": "predefinedCredentialType",
