        "url": "={{ $env.SKILLS_BASE_URL }}/scorer/write_caption_score",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"page_id\": \"{{ $json.page_id }}\",\n  \"score\": {{ $json.score }},\n  \"caption_fr\": \"{{ $json.caption_fr }}\",\n  \"caption_en\": \"{{ $json.caption_en }}\",\n  \"hashtags\": \"{{ $json.hashtags }}\"\n}",
        "options": {"timeout": 30000}
      },
      "id": "skill-write-caption-score",
      "name": "Skill · write_caption_score",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3040, 300],
      "credentials": {
        "httpHeaderAuth": {"id": "skills-bearer", "name": "Skills Service Bearer"}
      }
    },
    {
      "parameters": {
        "jsCode": "// Aggregate the 5 results, keep top 3 by score\nconst items = $input.all().map(i => i.json);\nitems.sort((a, b) => (b.score || 0) - (a.score || 0));\nreturn items.slice(0, 3).map(it => ({ json: it }));"
      },
      "id": "top3",
      "name": "Filter · Top 3 by score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3260, 300]
    },
