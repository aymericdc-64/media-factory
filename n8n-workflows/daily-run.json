        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": \"{{ $json.title }}\",\n  \"brief\": \"{{ $json.brief }}\",\n  \"script\": \"{{ $json.script }}\",\n  \"linked_agent\": \"Agent Strategist\"\n}",
        "options": {"timeout": 30000}
      },
      "id": "skill-write-brief",
      "name": "Skill · write_brief_to_pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1280, 300],
      "credentials": {
        "httpHeaderAuth": {"id": "skills-bearer", "name": "Skills Service Bearer"}
      }
