        "jsonBody": "={\n  \"chat_id\": \"{{ $env.TELEGRAM_CHAT_ID }}\",\n  \"video\": \"{{ $('Skill · upload_asset').item.json.url }}\",\n  \"caption\": \"🎬 *PROD-{{ $('Skill · write_brief_to_pipeline').item.json.prod_id }}* · score *{{ $json.score }}/10*\\n\\n{{ $json.caption_fr }}\\n\\n{{ $json.hashtags }}\",\n  \"parse_mode\": \"Markdown\",\n  \"reply_markup\": {\n    \"inline_keyboard\": [[\n      {\"text\": \"✅ Approve\", \"callback_data\": \"approve_PROD-{{ $('Skill · write_brief_to_pipeline').item.json.prod_id }}\"},\n      {\"text\": \"❌ Reject\", \"callback_data\": \"reject_PROD-{{ $('Skill · write_brief_to_pipeline').item.json.prod_id }}\"}\n    ]]\n  }\n}",
        "options": {"timeout": 30000}
      },
